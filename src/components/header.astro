---
import '../styles/global.css';
import { Icon }  from 'astro-icon/components';

---

<header>
    <nav class="pt-4">
        <div class="row header-row">
            <div class="col-lg col-sm-12 d-flex justify-content-around justify-content-lg-start">
                <a href="/">
                    <img
                        src="/assets/images/Sadhicari.svg"
                        alt="logo"
                        class="logo"
                    />
                </a>
            </div>
            <div class="col-lg col-sm-12  flex align-items-center">
                <ul class="nav justify-content-around justify-content-lg-end h-100 align-items-center" style="position: relative;">
                    <li class="nav-item me-3 header-resume-item">
                        <a class="header-resume-btn" href="/assets/Saugat_Adhikari_CV_03_26.pdf" download>
                            <Icon name="Download" />
                            Resume
                        </a>
                    </li>
                    <li class="nav-item me-3">
                        <a class="nav-link p-0" target="_blank" href="https://www.linkedin.com/in/saugatad/">
                            <Icon name="LinkedinLogo" />
                        </a>
                    </li>
                    <li class="nav-item me-3">
                        <a class="nav-link p-0" target="_blank" href="https://github.com/saugatnp">
                            <Icon name="Github" />
                        </a>
                    </li>
                    <li class="nav-item me-3">
                        <a class="nav-link p-0" href="mailto:saugatnp11@gmail.com">
                            <Icon name="Mail" />
                        </a>
                    </li>
                </ul>
            </div>
            <div class="col-lg-1 col-xs-0 d-none d-lg-block">
                &nbsp;
            </div>
        </div>
    </nav>
</header>
