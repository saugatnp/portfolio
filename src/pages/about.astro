---
import { Icon } from "astro-icon/components";
---

<div class="row d-flex justify-content-center mt-4">
    <div class="row d-flex mt-4 justify-content-center about-top-section">
        <div class="col-12 col-lg-10 about-top-block text-center mt-4 mt-lg-0">
            <p class="fs-4 m-0 about-kicker">So, Who am I?</p>
            <p class="index-intro-midtitle fs-1 primary-text">
                A software engineer who designs for scale.
            </p>
            <p class="light-text mt-2 mx-auto about-intro-text">
                I build modern web applications with a strong focus on
                maintainability, performance, and real business value.
                Recently, I have been delivering workflow automation modules
                using Angular 21, NgRx, and Signals, and expanding into
                backend integrations with Go, Redis, and AWS S3.
            </p>
            <div class="mt-4 about-cta-wrap">
                <a
                    href="/assets/Saugat_Adhikari_CV_03_26.pdf"
                    class="text-decoration-none py-2 px-4 circular-border-md primary-border primary-text cursor-pointer primary-btn-hover about-resume-btn"
                    download
                >
                    <b class="me-2">Download my resume</b>
                    <Icon
                        name="Download"
                        class="ms-2"
                        style="transform:scale(1.6)"
                    />
                </a>
            </div>
        </div>
    </div>

    <div class="about-logic-design-spacing about-bottom-grid row m-0 m-lg-auto d-flex justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="row align-items-center g-4 g-lg-5">
                <div class="col-12 col-lg-6 px-4 px-lg-4 mt-4 mt-lg-0">
            <h1 class="index-intro-midtitle fs-1">Logic & Design</h1>
            <p
                class="text-justify light-text mt-3"
                style="text-align: justify;"
            >
                My background in sketching and visual thinking helps me design
                user interfaces that are clear, practical, and human-centered.
                I enjoy balancing product design with engineering constraints to
                ship polished features quickly and reliably.
            </p>
                </div>
                <div class="col-12 col-lg-6 mt-3 mt-lg-0 about-right-visual">
            <div
                class="circular-slant-pattern d-flex justify-content-center justify-content-lg-end align-items-center"
            >
                <Icon name="logos" class="about-logo-group" />
            </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="row mt-0 mt-lg-2">
    <div class="col-sm-2 offset-3 offset-md-3">
        <p class="index-scroll text-center" style="margin-top:0">
            S&nbsp;C&nbsp;R&nbsp;O&nbsp;L&nbsp;L
        </p>
    </div>
</div>
