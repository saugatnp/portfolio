---

---

<div class="row d-flex justify-content-center mt-4">
    <p
        class="text-center fs-3 w-auto primary-border circular-border-md primary-text"
    >
        Contact&nbsp;Me
    </p>
    <p class="text-center contact-subtitle px-3">
        Open to software engineering roles, product collaborations, and freelance work.
        Reach out and I will get back to you soon.
    </p>

    <div class="row d-flex justify-content-center m-4">
        <div class="col-12 col-lg-10 col-xl-8 m-0 m-lg-2 p-0">
            <div class="contact-card primary-border circular-border-md p-4 p-lg-5">
                <div class="row mb-4 g-3">
                    <div class="col-12 col-md-4">
                        <a class="contact-link text-decoration-none" href="mailto:saugatnp11@gmail.com">
                            <span class="contact-link-label">Email</span>
                            <span class="contact-link-value">saugatnp11@gmail.com</span>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a class="contact-link text-decoration-none" target="_blank" href="https://www.linkedin.com/in/saugatad/">
                            <span class="contact-link-label">LinkedIn</span>
                            <span class="contact-link-value">/in/saugatad</span>
                        </a>
                    </div>
                    <div class="col-12 col-md-4">
                        <a class="contact-link text-decoration-none" target="_blank" href="https://github.com/saugatnp">
                            <span class="contact-link-label">GitHub</span>
                            <span class="contact-link-value">/saugatnp</span>
                        </a>
                    </div>
                </div>

            <form
                name="contact"
                method="POST"
                data-netlify="true"
                enctype="text/plain"
                class="contact-form"
            >
                <input type="hidden" name="form-name" value="contact" />

                <div class="row g-3 mt-0">
                    <div class="col-12 col-md-6">
                        <label class="input-label" for="name">Full Name</label>
                        <input type="text" id="name" name="name" required placeholder="Your name" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="input-label" for="email">Email Address</label>
                        <input type="email" id="email" name="email" required placeholder="you@example.com" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <label class="input-label" for="subject">Subject</label>
                        <input type="text" id="subject" name="subject" required placeholder="How can I help?" />
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-12">
                        <label class="input-label" for="message">Message</label>
                        <textarea id="message" name="message" rows="6" required placeholder="Write your message"></textarea>
                    </div>
                </div>

                <div class="row mt-4 text-center">
                    <div class="col-12 col-md-4 mx-auto">
                        <input type="submit" value="Send Message" />
                    </div>
                </div>
            </form>
            </div>
        </div>
    </div>
</div>
