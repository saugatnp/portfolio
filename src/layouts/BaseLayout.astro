---
import Bottomnavigation from "../components/bottomnavigation.astro";
import Header from "../components/header.astro";
import "bootstrap/dist/css/bootstrap.css";
import "../styles/global.css";
const { showBottomNavigation = true } = Astro.props;

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Saugat Adhikari</title>
	</head>
	<body>
		
		<div class="body-container d-flex flex-column" id="body-container">
			<Header />
			<slot />
		</div>
		{ showBottomNavigation && <Bottomnavigation />}
		<script>
			document.addEventListener("DOMContentLoaded", () => {
				const scrollRoot = document.querySelector(
					"#body-container",
				) as HTMLElement | null;
				const animatedElements = Array.from(
					document.querySelectorAll<HTMLElement>(".reveal-on-scroll"),
				);

				if (!animatedElements.length) return;

				const getRootRect = () => {
					if (scrollRoot instanceof HTMLElement) {
						return scrollRoot.getBoundingClientRect();
					}
					return {
						top: 0,
						bottom: window.innerHeight,
					};
				};

				const scrollTarget: HTMLElement | Window = scrollRoot ?? window;
				let fallbackAttached = false;

				function attachFallback() {
					if (fallbackAttached) return;
					fallbackAttached = true;
					scrollTarget.addEventListener("scroll", revealIfInView, { passive: true });
					window.addEventListener("resize", revealIfInView);
					window.addEventListener("orientationchange", revealIfInView);
				}

				function detachFallback() {
					if (!fallbackAttached) return;
					fallbackAttached = false;
					scrollTarget.removeEventListener("scroll", revealIfInView);
					window.removeEventListener("resize", revealIfInView);
					window.removeEventListener("orientationchange", revealIfInView);
				}

				function cleanupIfDone() {
					const allVisible = animatedElements.every((el) =>
						el.classList.contains("is-visible"),
					);
					if (allVisible) detachFallback();
				}

				function revealIfInView() {
					const rootRect = getRootRect();
					const revealLine =
						rootRect.bottom - (rootRect.bottom - rootRect.top) * 0.18;
					animatedElements.forEach((element) => {
						if (element.classList.contains("is-visible")) return;
						const rect = element.getBoundingClientRect();
						const isVisible =
							rect.top <= revealLine && rect.bottom >= rootRect.top;
						if (isVisible) element.classList.add("is-visible");
					});
					cleanupIfDone();
				}

				// Fallback for browsers where IntersectionObserver/root scrolling is flaky.
				attachFallback();

				// Always run once in case the first sections are already in view.
				revealIfInView();

				if (!("IntersectionObserver" in window)) return;

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-visible");
								observer.unobserve(entry.target);
							}
						});
						cleanupIfDone();
					},
					{
						threshold: 0.24,
						root: scrollRoot ?? null,
						rootMargin: "0px 0px -2% 0px",
					},
				);

				animatedElements.forEach((element) => observer.observe(element));
			});
		</script>
	</body>
	<div class="copyright text-white">
		<p>&copy; Saugat Adhikari. All rights reserved.</p>
	</div>
</html>
